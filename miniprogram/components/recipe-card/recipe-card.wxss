/* components/recipe-card/recipe-card.wxss */

.recipe-card {
  background: #FFFFFF;
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-md);
  transition: transform var(--duration-normal) var(--ease-spring),
              box-shadow var(--duration-normal) var(--ease-out);
}

.recipe-card:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-md);
}

/* === 封面区域 === */
.recipe-card__cover {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.recipe-card__image {
  width: 100%;
  height: 100%;
}

/* 无图片时的空白占位（不使用 emoji 或本地图片）*/
.recipe-card__placeholder--empty {
  width: 100%;
  height: 100%;
  background-color: #f0f0f0;
}

/* 匹配度徽章 */
.recipe-card__match-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 18rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(10px);
  border-radius: var(--radius-lg);
  gap: 2rpx;
  border: 1rpx solid rgba(255, 106, 136, 0.15);
}

.recipe-card__match-badge--ready {
  background: rgba(81, 207, 102, 0.92);
  border-color: rgba(81, 207, 102, 0.3);
}

.recipe-card__match-badge--ready .recipe-card__match-text,
.recipe-card__cook-label {
  color: #fff !important;
}

.recipe-card__match-text {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.recipe-card__cook-label {
  font-size: 18rpx;
  color: var(--status-fresh);
  font-weight: var(--font-weight-medium);
}

/* 难度标签 */
.recipe-card__difficulty {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* === 内容区 === */
.recipe-card__body {
  padding: 20rpx 24rpx 24rpx;
}

.recipe-card__name {
  display: block;
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-card__desc {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-hint);
  line-height: 1.5;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部元信息 */
.recipe-card__footer {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.recipe-card__meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
}

.recipe-card__meta-icon {
  font-size: 22rpx;
}

/* 标签滚动区 */
.recipe-card__tags-scroll {
  flex: 1;
  height: 36rpx;
  white-space: nowrap;
}

.recipe-card__tags {
  display: inline-flex;
  gap: 12rpx;
}

.recipe-card__tag {
  font-size: var(--font-size-xs);
  color: var(--color-primary-light);
  flex-shrink: 0;
}

/* 缺料提示 */
.recipe-card__missing {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: linear-gradient(135deg, #FFF8E1, #FFFBEB);
  border-radius: var(--radius-sm);
  border-left: 4rpx solid var(--color-warning);
}

.recipe-card__missing-icon {
  font-size: 24rpx;
}

.recipe-card__missing > text:last-child {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
