/* components/food-card/food-card.wxss */

.food-card {
  display: flex;
  align-items: stretch;
  background: #FFFFFF;
  border-radius: var(--radius-card);
  margin-bottom: var(--spacing-sm);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: transform var(--duration-normal) var(--ease-spring),
              box-shadow var(--duration-normal) var(--ease-out);
}

.food-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

/* 左侧颜色条 */
.food-card__color-bar {
  width: 8rpx;
  min-height: 100%;
  flex-shrink: 0;
}

/* 主要内容区 */
.food-card__content {
  flex: 1;
  padding: 24rpx 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 头部：名称 + 标签 */
.food-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.food-card__name {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  line-height: 1.3;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 元信息行 */
.food-card__meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-wrap: wrap;
}

.food-card__brand {
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
  background: var(--color-bg-secondary);
  padding: 2rpx 14rpx;
  border-radius: var(--radius-full);
}

.food-card__quantity {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.food-card__qty-num {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.food-card__qty-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
}

.food-card__location {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
}

.food-card__location-icon {
  font-size: 18rpx;
}

/* 保质期进度条 */
.food-card__expiry {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.food-card__expiry-bar {
  flex: 1;
  height: 6rpx;
  background: var(--color-border);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.food-card__expiry-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width var(--duration-slow) ease-out;
}

.food-card__expiry-fill--fresh {
  background: linear-gradient(90deg, var(--status-fresh), #8CE99A);
}

.food-card__expiry-fill--expiring {
  background: linear-gradient(90deg, var(--status-expiring), #FFE066);
  animation: expiry-pulse 1.5s ease-in-out infinite;
}

.food-card__expiry-fill--expired {
  background: linear-gradient(90deg, var(--status-expired), #FF8787);
}

@keyframes expiry-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.food-card__expiry-text {
  font-size: var(--font-size-xs);
  white-space: nowrap;
  flex-shrink: 0;
  width: 120rpx;
  text-align: right;
}

.text-fresh { color: var(--status-fresh); }
.text-expiring { color: #D9A40C; font-weight: 500; }
.text-expired { color: var(--status-expired); font-weight: 600; }

/* 右侧箭头 */
.food-card__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-right: 20rpx;
  color: var(--color-text-hint);
  font-size: 36rpx;
}

/* 过期状态特殊样式 */
.food-card--expired {
  opacity: 0.75;
  background: linear-gradient(135deg, #FFF5F5, #FFFFFF);
}

.food-card--expiring .food-card__content {
  position: relative;
}
