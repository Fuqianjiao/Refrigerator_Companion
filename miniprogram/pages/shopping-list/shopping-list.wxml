<!-- pages/shopping-list/shopping-list.wxml -->
<view class="page-container shopping-page">
  <!-- 顶部标题栏 -->
  <view class="shopping-header">
    <text class="header-title">🛒 购物清单</text>
    <text class="header-count">{{uncheckedCount}} 项待购</text>
  </view>

  <!-- 清单列表 -->
  <view class="list-section" wx:if="{{items.length > 0}}">
    <view 
      class="shop-item {{item.checked ? 'shop-item--checked' : ''}} stagger-item"
      wx:for="{{items}}"
      wx:key="{{index}}"
      data-index="{{index}}"
      bindtap="toggleCheck"
    >
      <!-- 复选框 -->
      <view class="checkbox {{item.checked ? 'checkbox--checked' : ''}}">
        <text>{{item.checked ? '✓' : ''}}</text>
      </view>
      
      <!-- 内容 -->
      <view class="item-content">
        <text class="item-name {{item.checked ? 'item-name--done' : ''}}">{{item.name}}</text>
        <text class="item-reason" wx:if="{{item.reason && !item.checked}}">{{item.reason}}</text>
      </view>

      <!-- 删除按钮 -->
      <view class="delete-btn" catchtap="removeItem" data-index="{{index}}">
        <text>✕</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:elif="{{!loading}}"
    icon="🛒"
    title="购物清单是空的"
    desc="浏览菜谱时点击「加入购物清单」，或者手动添加需要买的食材"
  />

  <!-- 底部操作栏 -->
  <view class="bottom-bar safe-area-bottom" wx:if="{{items.length > 0}}">
    <button class="btn-add-item" bindtap="showAddInput">
      <text>➕ 添加</text>
    </button>
    <button class="btn-clear-done" bindtap="clearChecked" wx:if="{{checkedCount > 0}}">
      <text>🗑 清除已完成 ({{checkedCount}})</text>
    </button>
  </view>

  <!-- 快速添加输入框（弹出式） -->
  <view class="add-input-overlay" wx:if="{{showAdd}}" bindtap="hideAddInput">
    <view class="add-input-panel" catchtap="">
      <input
        class="add-field"
        placeholder="输入要购买的食材..."
        value="{{newItemName}}"
        focus="{{showAdd}}"
        bindinput="onNewItemInput"
        confirm-type="done"
        bindconfirm="addItem"
      />
      <button class="add-confirm-btn" bindtap="addItem">添加</button>
    </view>
  </view>
</view>
