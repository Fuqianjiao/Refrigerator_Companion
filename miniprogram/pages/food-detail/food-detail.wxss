/* pages/food-detail/food-detail.wxss
 * 视觉风格：暖灰底色 + 圆角卡片 + 左对齐时间轴
 * 色彩系统：主色 #1a1a1a / 过期红 #E24B4A / AI 暖黄 #FAEEDA / 绿 #639922
 */

.detail-page {
  padding: 0 28rpx 180rpx;
  background: #f5f0eb;
  min-height: 100vh;
}

/* ==================== Hero 卡片 ==================== */
.hero-card {
  background: #fff;
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.food-name {
  font-size: 44rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.3;
}

/* 过期角标（红色药丸） */
.expired-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #FCEBEB;
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
  flex-shrink: 0;
}
.expired-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #E24B4A;
}
.expired-text {
  font-size: 22rpx;
  color: #A32D2D;
  font-weight: 500;
}

/* 临期角标（橙色） */
.expiring-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #FFF3E0;
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
  flex-shrink: 0;
}
.expiring-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #E67700;
}
.expiring-text {
  font-size: 22rpx;
  color: #A05600;
  font-weight: 500;
}

/* 分类标签 */
.category-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: #F1EFE8;
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #5F5E5A;
  margin-bottom: 28rpx;
}

/* 信息行：品牌 | 数量 | 位置 */
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 0;
}
.info-item {
  flex: 1;
  min-width: 0;
}
.info-label {
  font-size: 22rpx;
  color: #888780;
  margin-bottom: 4rpx;
}
.info-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}
.info-divider {
  width: 1rpx;
  height: 52rpx;
  background: #e8e5e0;
  margin: 0 28rpx;
  flex-shrink: 0;
  align-self: stretch;
  margin-top: 24rpx;
}

/* ==================== 通用卡片 ==================== */
.section-card {
  background: #fff;
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #888780;
  margin-bottom: 28rpx;
  letter-spacing: 0.02em;
}

/* ==================== 时间轴（左对齐式）==================== */
.timeline {
  position: relative;
  padding-left: 40rpx;
}

/* 渐变竖线背景：绿 → 红 */
.timeline-line {
  position: absolute;
  left: 10rpx;
  top: 16rpx;
  bottom: 16rpx;
  width: 3rpx;
  background: linear-gradient(to bottom, #97C459, #E24B4A);
  border-radius: 2rpx;
}

.timeline-item {
  position: relative;
  margin-bottom: 28rpx;
}
.timeline-item:last-child {
  margin-bottom: 0;
}

/* 圆点（绝对定位在左侧线上） */
.tl-dot {
  position: absolute;
  left: -40rpx;
  top: 6rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-sizing: border-box;
}
.tl-dot--green { background: #639922; }
.tl-dot--red { background: #E24B4A; }
.tl-dot--orange { background: #E67700; }
.tl-dot--gray { background: #B4B2A9; }
.tl-dot--today {
  background: #E24B4A;
  border-color: #FCEBEB;
  box-shadow: 0 0 0 4rpx #E24B4A;
}

.tl-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.tl-label { font-size: 22rpx; color: #888780; }
.tl-date { font-size: 28rpx; font-weight: 500; color: #1a1a1a; }

/* 过期日期红色 */
.tl-date--expired { color: #A32D2D; }
.tl-date--expiring { color: #A05600; }

/* 今天标签 */
.tl-today-badge {
  font-size: 22rpx;
  color: #A32D2D;
  background: #FCEBEB;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
  display: inline-block;
  margin-top: 4rpx;
}

/* ==================== 进度条 ==================== */
.progress-bar {
  margin-top: 28rpx;
  height: 8rpx;
  background: #F1EFE8;
  border-radius: 4rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.8s ease-out;
}
.progress-fill--fresh { background: #639922; }
.progress-fill--expiring { background: #E67700; }
.progress-fill--expired { background: #E24B4A; }

.progress-label {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}
.progress-label text { font-size: 20rpx; color: #B4B2A9; }

/* ==================== AI 处理建议（暖色调卡片）==================== */
.ai-section {
  background: #FAEEDA;
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}
.ai-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.ai-icon {
  width: 40rpx;
  height: 40rpx;
  background: #EF9F27;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ai-icon-inner {
  font-size: 22rpx;
  color: #fff;
  line-height: 1;
}
.ai-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #633806;
}
.ai-body {
  font-size: 26rpx;
  color: #854F0B;
  line-height: 1.75;
}
.ai-tip {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(186,117,23,0.2);
  font-size: 24rpx;
  color: #BA7517;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}
.ai-tip-icon { flex-shrink: 0; line-height: 1.4; }

/* ==================== 备注 ==================== */
.note-card {
  background: #fff;
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}
.note-content { font-size: 26rpx; color: var(--color-text-secondary); line-height: 1.7; }

/* ==================== 底部操作按钮 ==================== */
.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(245,240,235,0.95);
  backdrop-filter: blur(20px);
  z-index: 99;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  line-height: 88rpx;
  padding: 0;
}

.btn-primary {
  background: #1a1a1a;
  color: #fff;
}
.btn-secondary {
  background: #fff;
  color: #1a1a1a;
  border: 1rpx solid rgba(0,0,0,0.12);
}

.hover-scale { transform: scale(0.97); opacity: 0.92; }
.hover-scale-light { transform: scale(0.97); opacity: 0.85; background: #f5f5f5; }
