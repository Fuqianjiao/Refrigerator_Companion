/* pages/index/index.wxss */

/* === 页面容器 === */
.index-page {
  padding: 0 24rpx 40rpx;
  background: linear-gradient(180deg, var(--color-primary-light) 0%, var(--color-bg) 300rpx);
  min-height: 100vh;
}

/* === 问候区 === */
.greeting-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 8rpx 32rpx;
  animation: fade-in-up 0.5s ease-out both;
}

.greeting-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.greeting-time {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(255, 106, 136, 0.2);
}

.greeting-sub {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

.greeting-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
}
.greeting-avatar--logged {
  border-color: rgba(81, 207, 102, 0.7);
}

.avatar-img {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #FFE066, #FF9A8B);
}
.avatar-img--default {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #A5D8FF, #74C0FC) !important;
}

.avatar-emoji {
  font-size: 40rpx;
}

/* 登录状态在线圆点 */
.avatar-online-dot {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  width: 18rpx;
  height: 18rpx;
  background: #51CF66;
  border-radius: 50%;
  border: 3rpx solid #fff;
}

/* === 总览卡片 === */
.overview-card {
  position: relative;
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 32rpx 28rpx 28rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(255, 106, 136, 0.10);
}

.overview-card__gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: var(--color-primary-gradient);
}

.overview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.overview-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.overview-refresh {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg-secondary);
  transition: transform var(--duration-fast) ease-out;
}

.overview-refresh:active {
  transform: rotate(180deg) scale(0.9);
}

/* 统计数字网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: var(--color-bg);
  border-radius: var(--radius-lg);
  transition: transform var(--duration-fast) var(--ease-spring);
}

.stat-item:active {
  transform: scale(0.95);
}

.stat-item--primary {
  background: linear-gradient(135deg, rgba(255, 154, 139, 0.15), rgba(255, 106, 136, 0.10));
}

.stat-num {
  font-size: var(--font-size-xxl);
  font-weight: var(--font-weight-bold);
  line-height: 1.2;
  background: var(--color-primary-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-item--primary .stat-num,
.stat-item--warning .stat-num,
.stat-item--danger .stat-num {
  -webkit-text-fill-color: unset;
  background: none;
}

.stat-item--primary .stat-num { color: var(--color-primary); }
.stat-item--warning .stat-num { color: #E6A700; }
.stat-item--danger .stat-num { color: var(--color-danger); }

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
  margin-top: 4rpx;
}

/* 冰箱填充度 */
.fridge-level {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed var(--color-border);
}

.fridge-level__bar {
  height: 8rpx;
  background: var(--color-border);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.fridge-level__fill {
  height: 100%;
  background: var(--color-primary-gradient);
  border-radius: var(--radius-full);
  transition: width 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.fridge-level__text {
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
  text-align: center;
}

/* 空状态 */
.overview-empty {
  padding: 20rpx 0;
}

/* === 临期提醒横幅 === */
.expiry-banner {
  display: flex;
  align-items: center;
  margin: 24rpx 0;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #FFF3E0, #FFF8E1);
  border-radius: var(--radius-lg);
  border-left: 6rpx solid var(--color-warning);
  animation: pulse-gentle 2s ease-in-out infinite;
}

.expiry-banner__icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.expiry-banner__content {
  flex: 1;
  white-space: nowrap;
}

.expiry-banner__items {
  display: inline-flex;
  gap: 20rpx;
}

.expiry-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 16rpx;
  background: #fff;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.expiry-item__name {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  white-space: nowrap;
}

.expiry-item__time {
  font-size: 18rpx;
  white-space: nowrap;
}

.expiry-item__time--expiring { color: #D9A700; }
.expiry-item__time--expired { 
  color: var(--status-expired); 
  font-weight: 600; 
}

.expiry-banner__arrow {
  font-size: 32rpx;
  color: var(--color-text-hint);
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* === 区块标题 === */
.section {
  margin-bottom: 32rpx;
  animation: fade-in-up 0.5s ease-out both;
}

.section:nth-of-type(2) { animation-delay: 0.1s; }
.section:nth-of-type(3) { animation-delay: 0.2s; }

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.section-more {
  display: flex;
  align-items: center;
  gap: 2rpx;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

/* === 菜谱横向滚动 === */
.recipes-scroll {
  width: 100%;
  white-space: nowrap;
  margin: 0 calc(-1 * var(--spacing-md));
  padding: 0 var(--spacing-md);
}

.recipes-list {
  display: inline-flex;
  gap: var(--spacing-md);
}

.recipes-list > view {
  width: 520rpx !important;
  flex-shrink: 0;
}

/* === 快捷操作 === */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 28rpx 8rpx;
  margin-bottom: 24rpx;
  animation: fade-in-up 0.5s ease-out 0.15s both;
}

.quick-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.quick-action__icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
  transition: transform var(--duration-normal) var(--ease-spring);
}

.quick-action:active .quick-action__icon-wrap {
  transform: scale(0.92) translateY(-4rpx);
}

.quick-action__icon {
  font-size: 40rpx;
  line-height: 1;
}

.quick-action__label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

/* === 最近添加列表 === */
.recent-list {
  display: flex;
  flex-direction: column;
}

/* === 加载动画 === */
.loading-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dot {
  font-size: 24rpx;
  opacity: 0.3;
  color: var(--color-primary);
  animation: dot-bounce 1.4s ease-in-out infinite both;
}

.dot-1 { animation-delay: 0s; }
.dot-2 { animation-delay: 0.2s; }
.dot-3 { animation-delay: 0.4s; }

@keyframes dot-bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
  40% { transform: scale(1.2); opacity: 1; }
}
