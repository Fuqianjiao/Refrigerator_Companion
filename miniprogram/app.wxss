/* FridgeMate 全局样式 — 全部内联（WXSS 兼容） */
page {
  /* === 变量 === */
  --color-primary: #FF6A88;
  --color-primary-light: #FF9A8B;
  --color-primary-dark: #E84D6B;
  --color-primary-gradient: linear-gradient(135deg, #FF9A8B, #FF6A88);
  --color-sky: #74C0FC;
  --color-lemon: #FFE066;
  --color-lavender: #B692E4;
  --color-coral: #FF9A8B;
  --color-mint: #69DB7C;
  --color-bg: #FFF8F0;
  --color-card: #FFFFFF;
  --color-text-primary: #1A1A2E;
  --color-text-secondary: #555570;
  --color-text-hint: #9999AD;
  --color-border: #E8ECF0;
  --color-divider: #EEF0F2;
  --color-bg-secondary: #FFF0EB;
  --color-success: #51CF66;
  --color-warning: #FFD43B;
  --color-danger: #FF6B6B;
  --color-info: #74C0FC;
  --status-expiring: #FFA726;
  --status-expired: #EF5350;
  --status-fresh: #66BB6A;
  --gradient-warm: linear-gradient(135deg, #FF9A8B, #FF6A88);
  --gradient-cool: linear-gradient(135deg, #74C0FC, #B692E4);
  --gradient-fresh: linear-gradient(135deg, #69DB7C, #51CF66);
  --shadow-sm: 0 2rpx 8rpx rgba(255, 106, 136, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(255, 106, 136, 0.10);
  --shadow-lg: 0 8rpx 32rpx rgba(255, 106, 136, 0.14);
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 36rpx;
  --radius-round: 50%;
  --radius-full: 9999rpx;
  --radius-card: 22rpx;
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-md: 32rpx;
  --font-size-lg: 36rpx;
  --font-size-xl: 44rpx;
  --font-size-xxl: 56rpx;
  --font-size-title: 40rpx;
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;
  --font-weight-heavy: 800;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --duration-fast: 150ms;
  --duration-normal: 250ms;
  --duration-slow: 400ms;
  --duration-bounce: 600ms;
  --ease-default: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-in: cubic-bezier(0.4, 0, 1, 1);
  --ease-out: cubic-bezier(0, 0, 0.2, 1);
  --ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --z-base: 1;
  --z-dropdown: 100;
  --z-sticky: 200;
  --z-fixed: 300;
  --z-modal-backdrop: 400;
  --z-modal: 500;
  --z-popover: 600;
  --z-tooltip: 700;
  --z-toast: 800;
  --safe-area-inset-bottom: env(safe-area-inset-bottom);
  --safe-area-inset-top: env(safe-area-inset-top);
  --page-padding: 32rpx;
  --card-margin-bottom: 24rpx;
  --tabbar-height: 110rpx;

  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-size-base);
  line-height: 1.6;
}

/* === 动画 keyframes === */
@keyframes float-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}
@keyframes fade-in-up {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in-up { animation: fade-in-up 400ms ease-out both; }
@keyframes scale-in {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}
.animate-scale-in { animation: scale-in 250ms cubic-bezier(0.34, 1.56, 0.64, 1) both; }
@keyframes pulse-gentle {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.85; transform: scale(1.02); }
}
.animate-pulse { animation: pulse-gentle 2s ease-in-out infinite; }
@keyframes shake-gentle {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-4rpx); }
  40% { transform: translateX(4rpx); }
  60% { transform: translateX(-3rpx); }
  80% { transform: translateX(3rpx); }
}
.animate-shake { animation: shake-gentle 0.5s ease-in-out; }
@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}
.animate-fade-in { animation: fade-in 250ms ease-out both; }
.stagger-item { animation: fade-in-up 250ms ease-out both; }
.stagger-item:nth-child(1) { animation-delay: 0ms; }
.stagger-item:nth-child(2) { animation-delay: 60ms; }
.stagger-item:nth-child(3) { animation-delay: 120ms; }
.stagger-item:nth-child(4) { animation-delay: 180ms; }
.stagger-item:nth-child(5) { animation-delay: 240ms; }
.stagger-item:nth-child(6) { animation-delay: 300ms; }
.stagger-item:nth-child(7) { animation-delay: 360ms; }
.stagger-item:nth-child(8) { animation-delay: 420ms; }
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.animate-spin { animation: spin 1s linear infinite; }

/* === 容器 === */
.container {
  padding: var(--page-padding);
  padding-bottom: calc(var(--tabbar-height) + var(--spacing-xl));
  min-height: 100vh;
  box-sizing: border-box;
}
.page-container {
  padding: var(--page-padding);
  padding-bottom: calc(var(--tabbar-height) + var(--spacing-xl));
  min-height: 100vh;
  box-sizing: border-box;
}

/* === 卡片 === */
.card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-lg);
  margin-bottom: var(--card-margin-bottom);
  box-shadow: var(--shadow-card);
}
.card-simple {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  margin-bottom: var(--card-margin-bottom);
  box-shadow: var(--shadow-card);
}

/* === 按钮 === */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: var(--radius-xl);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  transition: all 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
}
.btn:active { transform: scale(0.96); }
.btn-primary {
  background: linear-gradient(135deg, #FF9A8B, #FF6A88);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255,106,136,0.35);
}
.btn-secondary {
  background: rgba(255, 106, 136, 0.1);
  color: #E84D6B;
}
.btn-block { width: 100%; }

/* === 标签 === */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 50%;
  font-size: 20rpx;
  font-weight: 500;
  white-space: nowrap;
}
.tag-green { background: rgba(81,207,102,0.12); color: #2B8A3E; }
.tag-blue { background: rgba(116,192,252,0.12); color: #1971C2; }
.tag-yellow { background: rgba(255,224,102,0.12); color: #E67700; }
.tag-red { background: rgba(255,107,107,0.10); color: #C92A2A; }

/* === 文字 === */
.text-primary { color: var(--color-text-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-hint { color: var(--color-text-hint); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }
.text-center { text-align: center; }
.font-bold { font-weight: var(--font-weight-bold); }
.font-semibold { font-weight: var(--font-weight-semibold); }

/* === 布局工具类 === */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }
.flex-shrink-0 { flex-shrink: 0; }
.gap-sm { gap: 16rpx; }
.gap-md { gap: 24rpx; }
.mt-xs { margin-top: 8rpx; }
.mt-sm { margin-top: 16rpx; }
.mt-md { margin-top: 24rpx; }
.mb-sm { margin-bottom: 16rpx; }
.mb-md { margin-bottom: 24rpx; }
.p-sm { padding: 16rpx; }
.p-md { padding: 24rpx; }

/* === 表单 === */
.input {
  height: 88rpx;
  padding: 0 28rpx;
  background: #FAFBFC;
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}
.input:focus {
  border-color: #FF6A88;
  box-shadow: 0 0 0 4rpx rgba(255,106,136,0.1);
}
.textarea {
  min-height: 180rpx;
  padding: 24rpx 28rpx;
  background: #FAFBFC;
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

/* === 空状态 === */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  color: var(--color-text-hint);
}
.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  animation: float-bounce 3s ease-in-out infinite;
}
.empty-text { font-size: 28rpx; margin-bottom: 24rpx; }

/* === 加载 === */
.loading-spinner {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid rgba(255,106,136,0.15);
  border-top-color: #FF6A88;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* === 分割线 === */
.divider { height: 1rpx; background: #EEF0F2; margin: 24rpx 0; }

/* === 头像 === */
.avatar { border-radius: 50%; overflow: hidden; flex-shrink: 0; }
.avatar-sm { width: 64rpx; height: 64rpx; }
.avatar-md { width: 96rpx; height: 96rpx; }
.avatar-lg { width: 128rpx; height: 128rpx; }

/* === 徽标 === */
.badge {
  display: inline-flex; align-items: center; justify-content: center;
  min-width: 32rpx; height: 32rpx; padding: 0 8rpx;
  background: #FF6B6B; color: #fff; font-size: 20rpx; border-radius: 50%;
}

/* === 列表 === */
.list-item {
  display: flex; align-items: center; padding: 24rpx 0;
  border-bottom: 1rpx solid #EEF0F2;
}
.list-item:last-child { border-bottom: none; }
.list-item:active { background: rgba(255,106,136,0.04); }

/* === 页面动画 === */
.page-enter { animation: pageSlideUp 0.35s ease-out both; }
@keyframes pageSlideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* === 安全区域 === */
.safe-area-bottom { padding-bottom: env(safe-area-inset-bottom); }
.safe-area-top { padding-top: env(safe-area-inset-top); }

/* === 隐藏滚动条 === */
::-webkit-scrollbar { display: none; width: 0; height: 0; }

/* === 装饰动效 === */
.bubble-float { animation: bubbleFloat 4s ease-in-out infinite; }
@keyframes bubbleFloat {
  0%, 100% { transform: translateY(0) scale(1); }
  33% { transform: translateY(-8rpx) scale(1.02); }
  66% { transform: translateY(4rpx) scale(0.98); }
}
.gentle-wiggle { animation: gentleWiggle 3s ease-in-out infinite; }
@keyframes gentleWiggle {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(1.5deg); }
  75% { transform: rotate(-1.5deg); }
}
.pulse-gentle-anim { animation: pulseGentle 2.5s ease-in-out infinite; }
@keyframes pulseGentle {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.04); opacity: 0.85; }
}
