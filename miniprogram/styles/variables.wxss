/* FridgeMate 全局样式变量 */
page {
  --color-primary: #FF6A88;
  --color-primary-light: #FF9A8B;
  --color-primary-dark: #E84D6B;
  --color-primary-gradient: linear-gradient(135deg, #FF9A8B, #FF6A88);
  --color-sky: #74C0FC;
  --color-lemon: #FFE066;
  --color-lavender: #B692E4;
  --color-coral: #FF9A8B;
  --color-mint: #69DB7C;
  --color-bg: #FFF8F0;
  --color-card: #FFFFFF;
  --color-text-primary: #1A1A2E;
  --color-text-secondary: #555570;
  --color-text-hint: #9999AD;
  --color-border: #E8ECF0;
  --color-divider: #EEF0F2;
  --color-bg-secondary: #FFF0EB;
  --color-success: #51CF66;
  --color-warning: #FFD43B;
  --color-danger: #FF6B6B;
  --color-info: #74C0FC;
  --status-expiring: #FFA726;
  --status-expired: #EF5350;
  --status-fresh: #66BB6A;
  --gradient-warm: linear-gradient(135deg, #FF9A8B, #FF6A88);
  --gradient-cool: linear-gradient(135deg, #74C0FC, #B692E4);
  --gradient-fresh: linear-gradient(135deg, #69DB7C, #51CF66);
  --shadow-sm: 0 2rpx 8rpx rgba(255, 106, 136, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(255, 106, 136, 0.10);
  --shadow-lg: 0 8rpx 32rpx rgba(255, 106, 136, 0.14);
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 36rpx;
  --radius-round: 50%;
  --radius-full: 9999rpx;
  --radius-card: 22rpx;
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-md: 32rpx;
  --font-size-lg: 36rpx;
  --font-size-xl: 44rpx;
  --font-size-xxl: 56rpx;
  --font-size-title: 40rpx;
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;
  --font-weight-heavy: 800;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --duration-fast: 150ms;
  --duration-normal: 250ms;
  --duration-slow: 400ms;
  --duration-bounce: 600ms;
  --ease-default: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-in: cubic-bezier(0.4, 0, 1, 1);
  --ease-out: cubic-bezier(0, 0, 0.2, 1);
  --ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --z-base: 1;
  --z-dropdown: 100;
  --z-sticky: 200;
  --z-fixed: 300;
  --z-modal-backdrop: 400;
  --z-modal: 500;
  --z-popover: 600;
  --z-tooltip: 700;
  --z-toast: 800;
  --safe-area-inset-bottom: env(safe-area-inset-bottom);
  --safe-area-inset-top: env(safe-area-inset-top);
  --page-padding: 32rpx;
  --card-margin-bottom: 24rpx;
  --tabbar-height: 110rpx;
}
